@{
    ViewData["Title"] = "Disneyland Resort | Star Wars Attractions";
}

<section class="park-detail-page container">
    <a class="back-btn link-btn btn btn-link text-secondary px-0" asp-controller="Home" asp-action="Index">&larr; Back</a>

    <div class="park-header border-bottom border-secondary-subtle">
        <h1 class="display-6 text-warning mb-1">Disneyland Resort</h1>
        <p class="text-secondary mb-0">Anaheim, California</p>
    </div>

    <div class="attraction-list">
        <article class="attraction-card card bg-dark text-light border-secondary-subtle shadow-sm">
            <h2 class="h4 text-warning mb-2">Star Wars: Galaxy's Edge</h2>
            <p class="text-light-emphasis">Explore attractions from Disney Parks around the world.</p>
            <div data-star-rating="5.0"></div>
            <div class="image-placeholder attraction-img"><span>[Galaxy's Edge Image]</span></div>

            <div class="review-prompt logged-out-view card bg-transparent border-secondary-subtle">
                <p class="text-secondary mb-1">Please log in to leave a review</p>
                <button type="button" class="btn btn-warning btn-sm fw-semibold" onclick="showLoginModal()">Log In / Sign Up</button>
            </div>

            <div class="reviews-section card bg-transparent border-secondary-subtle">
                <h3 class="h6 text-warning mb-3">Reviews (1)</h3>
                <div class="review-item">
                    <div class="reviewer-info">
                        <span class="avatar">RJ</span>
                        <strong>Rey Jakku</strong>
                        <span class="date">March 14, 2026</span>
                    </div>
                    <p>The level of detail in this land is unmatched. You really feel like you're on Batuu.</p>
                </div>
            </div>
        </article>
            
        <article class="attraction-card card bg-dark text-light border-secondary-subtle shadow-sm">
            <h2 class="h4 text-warning mb-2">Star Wars: Rise of the Resistance</h2>
            <p class="text-light-emphasis"><strong>RIDE:</strong> Epic battle between the Resistance and the First Order.</p>
            <div data-star-rating="4.9"></div>
            <div class="image-placeholder attraction-img"><span>[Rise of the Resistance Image]</span></div>

            <div class="review-prompt logged-out-view card bg-transparent border-secondary-subtle">
                <p class="text-secondary mb-1">Please log in to leave a review</p>
                <button type="button" class="btn btn-warning btn-sm fw-semibold" onclick="showLoginModal()">Log In / Sign Up</button>
            </div>

            <div class="reviews-section card bg-transparent border-secondary-subtle">
                <h3 class="h6 text-warning mb-3">Reviews (2)</h3>
                <div class="review-item">
                    <div class="reviewer-info">
                        <span class="avatar">LO</span>
                        <strong>Leia Organa</strong>
                        <span class="date">March 13, 2026</span>
                    </div>
                    <p>This ride is a masterpiece. The trackless system and the story are perfectly executed.</p>
                </div>
                <div class="review-item">
                    <div class="reviewer-info">
                        <span class="avatar">LS</span>
                        <strong>Luke Skywalker</strong>
                        <span class="date">March 9, 2026</span>
                    </div>
                    <p>Absolutely mind-blowing. The most immersive ride I've ever experienced.</p>
                </div>
            </div>
        </article>
    </div>
</section>
