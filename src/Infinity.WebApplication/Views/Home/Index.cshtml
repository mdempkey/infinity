@model Infinity.WebApplication.ViewModels.Home.IndexViewModel
@{
    ViewData["Title"] = "Star Wars Attractions";
}

<section class="home-page">
    <partial name="_Globe" />
    <div class="home-page__scrim"></div>
    <button type="button" class="home-page__reset" onclick="resetHomepageGlobe()">Back to Globe</button>

    <div class="home-page__content">
        <section class="home-hero">
            <section class="location-panel location-panel--parks">
                @foreach (var park in Model.Parks)
                {
                    <article class="attraction-card location-card location-card--clickable"
                             role="button"
                             tabindex="0"
                             aria-label="Focus @park.Title on map"
                             onclick="focusHomepagePark('@park.Id')"
                             onkeydown="if (event.key === 'Enter' || event.key === ' ') { event.preventDefault(); focusHomepagePark('@park.Id'); }">
                        <h3>@park.Title</h3>
                        <p>@park.City, @park.Country</p>
                    </article>
                }
            </section>

            <section class="location-panel attraction-panel" id="attraction-panel">
                <div id="attraction-panel-list"></div>
            </section>
        </section>
    </div>

    <partial name="_AttractionWidget" />
</section>
