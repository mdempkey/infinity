@{
    ViewData["Title"] = "Star Wars Attractions";
}

<section class="home-page">
    <partial name="_HomepageGlobe" />
    <div class="home-page__scrim"></div>
    <button type="button" class="home-page__reset" onclick="resetHomepageGlobe()">Back to Parks</button>

    <div class="home-page__content">
        <section class="home-hero">
            <section class="location-panel">
                <article class="attraction-card location-card">
                    <h3>Disneyland Resort</h3>
                    <p>Anaheim, California</p>
                    <p>Galaxy's Edge and Rise of the Resistance.</p>
                    <button type="button" class="yellow-btn inline-btn" onclick="focusHomepagePark('disneyland')">Focus Park</button>
                </article>

                <article class="attraction-card location-card">
                    <h3>Disneyland Paris</h3>
                    <p>Marne-la-Vallee, France</p>
                    <p>Star Tours and Hyperspace Mountain.</p>
                    <button type="button" class="yellow-btn inline-btn" onclick="focusHomepagePark('disneyland-paris')">Focus Park</button>
                </article>
            </section>
        </section>
    </div>
</section>
