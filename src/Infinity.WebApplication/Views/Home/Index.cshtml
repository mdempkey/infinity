@model Infinity.WebApplication.ViewModels.Home.IndexViewModel
@{
ViewData["Title"] = "Infinity Site";
}

<style>
    .location-card,
    .attraction-card {
        border: 1px solid rgba(255, 204, 0, 0.22);
        border-radius: 22px;
        box-shadow: 0 14px 34px rgba(0, 0, 0, 0.34);
        backdrop-filter: blur(12px);
        transition:
            transform 0.24s ease,
            box-shadow 0.24s ease,
            border-color 0.24s ease,
            filter 0.24s ease;
    }

    .location-card:hover,
    .attraction-card:hover {
        transform: translateY(-5px) scale(1.015);
        border-color: rgba(25, 183, 255, 0.58);
        box-shadow:
            0 18px 42px rgba(0, 0, 0, 0.46),
            0 0 24px rgba(25, 183, 255, 0.14);
        filter: brightness(1.06);
    }

    .location-card:active,
    .attraction-card:active {
        transform: scale(0.985);
    }

    .homepage-globe__marker {
        box-shadow:
            0 0 0 2px rgba(255, 204, 0, 0.42),
            0 0 20px rgba(255, 204, 0, 0.28);
        transition:
            transform 0.2s ease,
            box-shadow 0.2s ease,
            filter 0.2s ease;
        animation: markerPulse 2.4s ease-in-out infinite;
    }

    .homepage-globe__marker:hover {
        transform: scale(1.18);
        filter: brightness(1.2);
        box-shadow:
            0 0 0 3px rgba(25, 183, 255, 0.6),
            0 0 28px rgba(25, 183, 255, 0.42);
    }

    @@keyframes markerPulse {
        0%, 100% {
            box-shadow:
                0 0 0 2px rgba(255, 204, 0, 0.36),
                0 0 18px rgba(255, 204, 0, 0.22);
        }

        50% {
            box-shadow:
                0 0 0 4px rgba(255, 204, 0, 0.18),
                0 0 30px rgba(255, 204, 0, 0.42);
        }
    }

    .home-page__reset {
        border-radius: 999px;
        border-color: rgba(255, 204, 0, 0.55);
        background: rgba(3, 10, 28, 0.72);
        color: white;
        box-shadow: 0 0 18px rgba(255, 204, 0, 0.14);
        transition:
            transform 0.2s ease,
            box-shadow 0.2s ease,
            background-color 0.2s ease;
    }

    .home-page__reset:hover {
        transform: translateY(-2px);
        background: rgba(25, 183, 255, 0.18);
        box-shadow:
            0 10px 24px rgba(0, 0, 0, 0.36),
            0 0 24px rgba(25, 183, 255, 0.22);
    }

    .attraction-panel__controls {
        background:
            linear-gradient(135deg, rgba(4, 10, 28, 0.82), rgba(8, 18, 45, 0.72));
        border: 1px solid rgba(255, 204, 0, 0.2);
        border-radius: 20px;
        padding: 0.75rem;
        box-shadow: 0 12px 30px rgba(0, 0, 0, 0.3);
        backdrop-filter: blur(12px);
        transition:
            transform 0.22s ease,
            border-color 0.22s ease,
            box-shadow 0.22s ease;
    }

    .attraction-panel__controls:hover {
        transform: translateY(-2px);
        border-color: rgba(25, 183, 255, 0.42);
        box-shadow: 0 16px 36px rgba(0, 0, 0, 0.38);
    }

    #attraction-search,
    #attraction-sort {
        border-radius: 999px;
        border: 1px solid rgba(255, 204, 0, 0.28);
        background-color: rgba(2, 7, 22, 0.92);
        color: white;
        font-weight: 600;
        transition:
            transform 0.18s ease,
            border-color 0.18s ease,
            box-shadow 0.18s ease,
            background-color 0.18s ease;
    }

    #attraction-search::placeholder {
        color: rgba(255,255,255,0.55);
    }

    #attraction-search:hover,
    #attraction-sort:hover {
        transform: translateY(-1px);
        border-color: rgba(255, 204, 0, 0.56);
        box-shadow: 0 0 16px rgba(255, 204, 0, 0.12);
    }

    #attraction-search:focus,
    #attraction-sort:focus {
        background-color: rgba(2, 7, 22, 0.98);
        color: white;
        border-color: rgba(25, 183, 255, 0.76);
        box-shadow:
            0 0 0 0.25rem rgba(25, 183, 255, 0.16),
            0 0 22px rgba(25, 183, 255, 0.18);
        outline: none;
    }

    #attraction-sort {
        cursor: pointer;
        min-width: 150px;
    }

    #attraction-sort option {
        background-color: #071126;
        color: white;
    }

    .attraction-panel__controls.is-sorting {
        animation: sortPulse 0.35s ease;
    }

    @@keyframes sortPulse {
        0% {
            transform: scale(1);
        }

        50% {
            transform: scale(1.018);
            box-shadow: 0 0 30px rgba(255, 204, 0, 0.26);
        }

        100% {
            transform: scale(1);
        }
    }

    .star-rating {
        color: #ffcc00;
        letter-spacing: 2px;
        text-shadow: 0 0 14px rgba(255, 204, 0, 0.5);
    }

    .magic-cursor {
        position: fixed;
        width: 18px;
        height: 18px;
        border: 2px solid rgba(255, 204, 0, 0.9);
        border-radius: 999px;
        pointer-events: none;
        z-index: 9999;
        transform: translate(-50%, -50%);
        box-shadow:
            0 0 16px rgba(255, 204, 0, 0.5),
            0 0 28px rgba(25, 183, 255, 0.22);
        transition:
            width 0.15s ease,
            height 0.15s ease,
            border-color 0.15s ease,
            background-color 0.15s ease;
    }

    .magic-cursor.is-hovering {
        width: 34px;
        height: 34px;
        border-color: rgba(25, 183, 255, 0.95);
        background-color: rgba(25, 183, 255, 0.08);
    }

    .magic-cursor-dot {
        position: fixed;
        width: 5px;
        height: 5px;
        border-radius: 999px;
        background: #ffcc00;
        pointer-events: none;
        z-index: 10000;
        transform: translate(-50%, -50%);
        box-shadow: 0 0 12px rgba(255, 204, 0, 0.8);
    }

    .pokemon-music-hub {
        position: relative;
        animation: pokemonGlowPulse 2.4s ease-in-out infinite;
    }

    .pokemon-music-hub::before,
    .pokemon-music-hub::after {
        position: absolute;
        pointer-events: none;
        color: #ffcc00;
        font-size: 1.1rem;
        text-shadow: 0 0 12px rgba(255, 204, 0, 0.8);
        opacity: 0;
        z-index: 5;
    }

    .pokemon-music-hub::before {
        content: "♪ ♫";
        left: 18%;
        top: -0.8rem;
        animation: floatingNotesLeft 2.2s ease-in-out infinite;
    }

    .pokemon-music-hub::after {
        content: "♫ ♪";
        right: 18%;
        top: -0.8rem;
        animation: floatingNotesRight 2.6s ease-in-out infinite;
    }

    .pokemon-music-dance {
        display: inline-block;
        animation: pokemonTextDance 1.6s ease-in-out infinite;
        text-shadow:
            0 0 8px rgba(25, 183, 255, 0.75),
            0 0 16px rgba(255, 204, 0, 0.45);
    }

    #pokemonSelector {
        animation: pokemonSelectBounce 2.8s ease-in-out infinite;
    }

    #pokemonSelector:hover {
        box-shadow:
            0 0 0 0.2rem rgba(255, 204, 0, 0.14),
            0 0 22px rgba(25, 183, 255, 0.28);
    }

    @@keyframes pokemonTextDance {
        0%, 100% {
            transform: translateY(0) rotate(0deg);
        }

        25% {
            transform: translateY(-2px) rotate(-1deg);
        }

        50% {
            transform: translateY(1px) rotate(1deg);
        }

        75% {
            transform: translateY(-1px) rotate(-0.5deg);
        }
    }

    @@keyframes pokemonGlowPulse {
        0%, 100% {
            filter: drop-shadow(0 0 8px rgba(25, 183, 255, 0.18));
        }

        50% {
            filter: drop-shadow(0 0 18px rgba(255, 204, 0, 0.35));
        }
    }

    @@keyframes floatingNotesLeft {
        0% {
            opacity: 0;
            transform: translateY(8px) rotate(-8deg) scale(0.85);
        }

        35% {
            opacity: 1;
        }

        100% {
            opacity: 0;
            transform: translateY(-16px) rotate(8deg) scale(1.08);
        }
    }

    @@keyframes floatingNotesRight {
        0% {
            opacity: 0;
            transform: translateY(8px) rotate(8deg) scale(0.85);
        }

        35% {
            opacity: 1;
        }

        100% {
            opacity: 0;
            transform: translateY(-16px) rotate(-8deg) scale(1.08);
        }
    }

    @@keyframes pokemonSelectBounce {
        0%, 100% {
            transform: translateY(0);
        }

        50% {
            transform: translateY(-1px);
        }
    }

    @@media (max-width: 800px) {
        .magic-cursor,
        .magic-cursor-dot {
            display: none;
        }

        .attraction-panel__controls {
            flex-direction: column;
        }

        #attraction-sort {
            width: 100% !important;
        }
    }

    @@media (prefers-reduced-motion: reduce) {
        *,
        *::before,
        *::after {
            animation-duration: 0.001ms !important;
            animation-iteration-count: 1 !important;
            transition-duration: 0.001ms !important;
            scroll-behavior: auto !important;
        }

        .magic-cursor,
        .magic-cursor-dot {
            display: none;
        }
    }
</style>

<section class="home-page">
    <partial name="_Globe" />
    <div class="home-page__scrim"></div>
    <button type="button" class="home-page__reset btn btn-outline-primary btn-sm px-3 py-2" onclick="resetHomepageGlobe()">Back to Globe</button>

    <div class="home-page__content">
        <section class="home-hero">
            <section class="location-panel location-panel--parks">
                @foreach (var park in Model.Parks)
                {
                <article class="attraction-card location-card location-card--clickable card text-bg"
                         role="button"
                         tabindex="0"
                         aria-label="Focus @park.Title on map"
                         onclick="focusHomepagePark('@park.Id')"
                         onkeydown="if (event.key === 'Enter' || event.key === ' ') { event.preventDefault(); focusHomepagePark('@park.Id'); }">
                    <h3 class="h5 text-primary mb-1">@park.Title</h3>
                    <p class="text-secondary mb-0">@park.City, @park.Country</p>
                </article>
                }
            </section>

            <section class="location-panel attraction-panel" id="attraction-panel">
                <div class="attraction-panel__controls d-flex gap-2 mb-3" id="attraction-controls" hidden>
                    <input type="search"
                           class="form-control form-control-sm"
                           id="attraction-search"
                           placeholder="Search attractions…"
                           aria-label="Search attractions" />
                    <select class="form-select form-select-sm w-auto flex-shrink-0"
                            id="attraction-sort"
                            aria-label="Sort attractions">
                        <option value="default">Default</option>
                        <option value="name-asc">Name A–Z</option>
                        <option value="name-desc">Name Z–A</option>
                        <option value="rating-desc">Highest Rated</option>
                        <option value="rating-asc">Lowest Rated</option>
                    </select>
                </div>
                <div id="attraction-panel-list" class="d-grid gap-3"></div>
            </section>
        </section>
    </div>

    <partial name="_AttractionWidget" />
</section>

@section Scripts {
<script>
    document.addEventListener('DOMContentLoaded', function() {
        const attractionSort = document.getElementById('attraction-sort');
        const attractionControls = document.getElementById('attraction-controls');

        attractionSort?.addEventListener('change', function () {
            attractionControls?.classList.remove('is-sorting');

            window.setTimeout(() => {
                attractionControls?.classList.add('is-sorting');
            }, 10);

            window.setTimeout(() => {
                attractionControls?.classList.remove('is-sorting');
            }, 380);
        });

        const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        const isTouchDevice = window.matchMedia('(pointer: coarse)').matches;

        if (!prefersReducedMotion && !isTouchDevice) {
            const cursor = document.createElement('div');
            const cursorDot = document.createElement('div');

            cursor.className = 'magic-cursor';
            cursorDot.className = 'magic-cursor-dot';

            document.body.append(cursor, cursorDot);

            window.addEventListener('mousemove', function (event) {
                cursor.style.left = `${event.clientX}px`;
                cursor.style.top = `${event.clientY}px`;

                cursorDot.style.left = `${event.clientX}px`;
                cursorDot.style.top = `${event.clientY}px`;
            });

            document.addEventListener('mouseover', function (event) {
                if (event.target.closest('button, a, input, select, textarea, .location-card, .attraction-card')) {
                    cursor.classList.add('is-hovering');
                }
            });

            document.addEventListener('mouseout', function (event) {
                if (event.target.closest('button, a, input, select, textarea, .location-card, .attraction-card')) {
                    cursor.classList.remove('is-hovering');
                }
            });
        }

        const pokemonSelector = document.getElementById('pokemonSelector');

        if (pokemonSelector) {
            const pokemonHub = pokemonSelector.closest('div, section, nav, header') ?? pokemonSelector.parentElement;

            if (pokemonHub) {
                pokemonHub.classList.add('pokemon-music-hub');
            }

            document.querySelectorAll('body *').forEach((element) => {
                const text = element.textContent?.trim() ?? "";

                if (
                    text.includes('Pokémon') &&
                    text.length < 80 &&
                    !element.matches('script, style, select, option')
                ) {
                    element.classList.add('pokemon-music-dance');
                }
            });
        }

        const playBtn = document.getElementById('playSongBtn');
        const selector = document.getElementById('pokemonSelector');
        const audioPlayer = document.getElementById('starWarsAudio');

        if (playBtn && selector && audioPlayer) {
            playBtn.addEventListener('click', function() {
                const selectedOption = selector.options[selector.selectedIndex];

                if (!selectedOption.value) {
                    alert("Please select a Pokémon first!");
                    return;
                }

                const songType = selectedOption.getAttribute('data-song');

                const songDirectory = {
                    'cantina': '/audio/cantina-band.mp3',
                    'imperial': '/audio/imperial-march.mp3',
                    'main_theme': '/audio/star-wars-theme.mp3'
                };

                if (songDirectory[songType]) {
                    audioPlayer.src = songDirectory[songType];
                    audioPlayer.currentTime = 0;

                    audioPlayer.play()
                        .then(() => console.log("Now playing Star Wars audio for: " + selectedOption.value))
                        .catch(error => console.error("Error playing audio. Make sure the audio files exist in wwwroot/audio:", error));
                }
            });
        }
    });
</script>
}