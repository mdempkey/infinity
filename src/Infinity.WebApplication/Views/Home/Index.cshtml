@model Infinity.WebApplication.ViewModels.Home.IndexViewModel
@{
    ViewData["Title"] = "Infinity Site";
}

<section class="home-page">
    <partial name="_Globe" />
    <div class="home-page__scrim"></div>
    <button type="button" class="home-page__reset btn btn-outline-primary btn-sm px-3 py-2" onclick="resetHomepageGlobe()">Back to Globe</button>

    <div class="home-page__content">
        <section class="home-hero">
            <section class="location-panel location-panel--parks">
                @foreach (var park in Model.Parks)
                {
                    <article class="attraction-card location-card location-card--clickable card text-bg"
                             role="button"
                             tabindex="0"
                             aria-label="Focus @park.Title on map"
                             onclick="focusHomepagePark('@park.Id')"
                             onkeydown="if (event.key === 'Enter' || event.key === ' ') { event.preventDefault(); focusHomepagePark('@park.Id'); }">
                        <h3 class="h5 text-primary mb-1">@park.Title</h3>
                        <p class="text-secondary mb-0">@park.City, @park.Country</p>
                    </article>
                }
            </section>

            <section class="location-panel attraction-panel" id="attraction-panel">
                <div class="attraction-panel__controls d-flex gap-2 mb-3" id="attraction-controls" hidden>
                    <input type="search"
                           class="form-control form-control-sm"
                           id="attraction-search"
                           placeholder="Search attractions…"
                           aria-label="Search attractions" />
                    <select class="form-select form-select-sm w-auto flex-shrink-0"
                            id="attraction-sort"
                            aria-label="Sort attractions">
                        <option value="default">Default</option>
                        <option value="name-asc">Name A–Z</option>
                        <option value="name-desc">Name Z–A</option>
                        <option value="rating-desc">Highest Rated</option>
                        <option value="rating-asc">Lowest Rated</option>
                    </select>
                </div>
                <div id="attraction-panel-list" class="d-grid gap-3"></div>
            </section>
        </section>
    </div>

    <partial name="_AttractionWidget" />
</section>
