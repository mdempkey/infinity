@{
    ViewData["Title"] = "Disneyland Paris | Star Wars Attractions";
}

<section class="park-detail-page">
    <a class="back-btn link-btn" asp-controller="Home" asp-action="Index">&larr; Back</a>

    <div class="park-header">
        <h1>Disneyland Paris</h1>
        <p>Marne-la-Vallee, France</p>
    </div>

    <div class="attraction-list">
        <article class="attraction-card">
            <h2>Star Tours: The Adventures Continue</h2>
            <p><strong>RIDE:</strong> 3D motion simulator space flight.</p>
            <div class="star-rating">★★★★☆ 4.5</div>
            <div class="image-placeholder attraction-img"><span>[Star Tours Image]</span></div>

            <div class="review-prompt">
                <p>Please log in to leave a review</p>
                <button type="button" class="yellow-btn" onclick="showLoginModal()">Log In / Sign Up</button>
            </div>

            <div class="reviews-section">
                <h3>Reviews</h3>
                <p class="empty-reviews">No reviews yet. Be the first to leave a review.</p>
            </div>
        </article>

        <article class="attraction-card">
            <h2>Hyperspace Mountain</h2>
            <p><strong>RIDE:</strong> High-speed indoor roller coaster.</p>
            <div class="star-rating">★★★★☆ 4.2</div>
            <div class="image-placeholder attraction-img"><span>[Hyperspace Mountain Image]</span></div>

            <div class="review-prompt">
                <p>Please log in to leave a review</p>
                <button type="button" class="yellow-btn" onclick="showLoginModal()">Log In / Sign Up</button>
            </div>
        </article>
    </div>
</section>
