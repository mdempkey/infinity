<script>
    (() => {
        const configNode = document.getElementById("homepage-globe-config");
        if (!configNode) {
            return;
        }

        let config;
        try {
            config = JSON.parse(configNode.textContent ?? "{}");
        } catch {
            return;
        }

        const accessToken = config?.accessToken ?? "";
        const initialCenter = config?.globe?.initialCenter ?? [20, 15];
        const initialZoom = config?.globe?.initialZoom ?? 1.55;
        const focusedZoom = config?.globe?.focusedZoom ?? 15.3;
        const parks = Array.isArray(config?.parks) ? config.parks : [];

        const mount = document.getElementById("homepage-globe");
        const wrapper = mount?.parentElement;
        const homePage = document.querySelector(".home-page");
        if (!mount || !wrapper) {
            return;
        }

        const getLocationPanel = () => document.querySelector(".location-panel--parks");
        const getAttractionPanelList = () => document.getElementById("attraction-panel-list");
        const getAttractionControls = () => document.getElementById("attraction-controls");
        const getSearchInput = () => document.getElementById("attraction-search");
        const getSortSelect = () => document.getElementById("attraction-sort");

        function initHomepageGlobe() {
            if (!window.mapboxgl) {
                return;
            }

            mapboxgl.accessToken = accessToken;

            const map = new mapboxgl.Map({
                container: mount,
                style: "mapbox://styles/mapbox/standard-satellite",
                projection: "globe",
                center: initialCenter,
                zoom: initialZoom,
                minZoom: initialZoom,
                maxZoom: focusedZoom,
                dragRotate: false,
                dragPan: true,
                doubleClickZoom: false,
                scrollZoom: false,
                boxZoom: false,
                keyboard: false,
                touchZoomRotate: true,
                attributionControl: false,
                pitchWithRotate: false,
                config: {
                    basemap: {
                        showPedestrianRoads: false,
                        showPlaceLabels: false,
                        showPointOfInterestLabels: false,
                        showRoadLabels: false,
                        showTransitLabels: false,
                        showAdminBoundaries: false,
                        showRoadsAndTransit: false
                    }
                }
            });

            let hasLoaded = false;
            let readyTimeout = null;
            let readyCheckBound = false;

            const showFallback = () => {
                if (!hasLoaded) {
                    wrapper.classList.remove("is-ready");
                    wrapper.classList.add("is-fallback");
                }
            };

            readyTimeout = window.setTimeout(() => {
                showFallback();
            }, 6000);

            const markReadyIfLoaded = () => {
                const tilesReady = typeof map.areTilesLoaded === "function" ? map.areTilesLoaded() : false;
                const styleReady = typeof map.isStyleLoaded === "function" ? map.isStyleLoaded() : false;

                if (!styleReady || !tilesReady) {
                    return;
                }

                hasLoaded = true;
                if (readyTimeout) {
                    window.clearTimeout(readyTimeout);
                    readyTimeout = null;
                }

                wrapper.classList.remove("is-fallback");
                wrapper.classList.add("is-ready");
                map.off("render", markReadyIfLoaded);
            };

            map.on("error", showFallback);

            map.on("style.load", () => {
                if (!readyCheckBound) {
                    readyCheckBound = true;
                    map.on("render", markReadyIfLoaded);
                }
            });

            const parkMarkers = [];
            let attractionMarkers = [];
            let focusedPark = null;
            let currentAttractions = [];
            const resetZoomThreshold = 0.01;
            const resetCenterThreshold = 0.02;

            const clearAttractionMarkers = () => {
                attractionMarkers.forEach((marker) => marker.remove());
                attractionMarkers = [];
            };

            const escapeHtml = (value) => value
                .replaceAll("&", "&amp;")
                .replaceAll("<", "&lt;")
                .replaceAll(">", "&gt;")
                .replaceAll("\"", "&quot;")
                .replaceAll("'", "&#39;");

            const addAttractionMarkers = (park) => {
                clearAttractionMarkers();

                (park.attractions ?? []).forEach((attraction) => {
                    const markerElement = document.createElement("button");
                    markerElement.type = "button";
                    markerElement.className = "homepage-globe__marker";
                    markerElement.setAttribute("aria-label", attraction.title);
                    markerElement.addEventListener("click", () => {
                        window.openHomepageAttractionWidget?.({
                            parkTitle: park.title,
                            parkLocation: `${park.location}, ${park.country}`,
                            attractionTitle: attraction.title,
                            attractionSubtitle: attraction.subtitle,
                            attractionRating: attraction.rating,
                            attractionId: attraction.id
                        });
                    });

                    const marker = new mapboxgl.Marker({ element: markerElement, anchor: "center" })
                        .setLngLat(attraction.coordinates)
                        .addTo(map);

                    attractionMarkers.push(marker);
                });
            };

            const hydrateAttractionRatings = (attractions) => {
                attractions.forEach(async (attraction) => {
                    if (!attraction.id) return;
                    try {
                        const res = await fetch(`/api/ratings/${attraction.id}/mine`);
                        if (!res.ok) return;
                        const data = await res.json();
                        if (data.average == null) return;
                        const container = document.querySelector(`[data-rating-container="${attraction.id}"]`);
                        if (!container) return;
                        container.innerHTML = window.renderHomepageStarRating?.(data.average) ?? "";
                    } catch {
                        // leave initial render in place
                    }
                });
            };

            // STAR-35: Returns attractions sorted by the current sort selection
            const getSortedAttractions = (attractions) => {
                const sort = getSortSelect()?.value ?? "default";
                const list = [...attractions];
                if (sort === "name-asc") return list.sort((a, b) => a.title.localeCompare(b.title));
                if (sort === "name-desc") return list.sort((a, b) => b.title.localeCompare(a.title));
                if (sort === "rating-desc") return list.sort((a, b) => (b.rating ?? 0) - (a.rating ?? 0));
                if (sort === "rating-asc") return list.sort((a, b) => (a.rating ?? 0) - (b.rating ?? 0));
                return list;
            };

            // STAR-36: Returns attractions filtered by the current search query
            const getFilteredAttractions = (attractions) => {
                const query = getSearchInput()?.value.trim().toLowerCase() ?? "";
                if (!query) return attractions;
                return attractions.filter(a =>
                    a.title.toLowerCase().includes(query) ||
                    a.subtitle.toLowerCase().includes(query)
                );
            };

            // Applies current search + sort state and re-renders the list
            const renderAttractionList = (attractions) => {
                const attractionPanelList = getAttractionPanelList();
                if (!attractionPanelList) return;

                const visible = getSortedAttractions(getFilteredAttractions(attractions));

                if (visible.length === 0) {
                    attractionPanelList.innerHTML = `<p class="text-secondary fst-italic">No attractions match your search.</p>`;
                    return;
                }

                attractionPanelList.innerHTML = visible
                    .map((attraction) => `
                        <article class="attraction-card location-card location-card--clickable card text-bg"
                                 role="button"
                                 tabindex="0"
                                 data-attraction-id="${escapeHtml(attraction.id ?? "")}"
                                 aria-label="View details for ${escapeHtml(attraction.title)}">
                            <h3 class="h5 text-primary mb-1">${escapeHtml(attraction.title)}</h3>
                            <span data-rating-container="${escapeHtml(attraction.id ?? "")}">
                                ${window.renderHomepageStarRating?.(attraction.rating) ?? ""}
                            </span>
                            <p class="text-secondary mb-0">${escapeHtml(attraction.subtitle)}</p>
                        </article>
                    `)
                    .join("");

                hydrateAttractionRatings(visible);
            };

            const renderAttractions = (park) => {
                currentAttractions = park.attractions ?? [];

                // Reset controls to default state when switching parks
                const searchInput = getSearchInput();
                const sortSelect = getSortSelect();
                if (searchInput) searchInput.value = "";
                if (sortSelect) sortSelect.value = "default";

                renderAttractionList(currentAttractions);
            };

            const bindAttractionPanelInteractions = () => {
                if (!homePage) {
                    return;
                }

                const activateAttractionFromEvent = (targetNode) => {
                    const targetElement = targetNode instanceof Element
                        ? targetNode
                        : targetNode instanceof Node
                            ? targetNode.parentElement
                            : null;
                    if (!targetElement) {
                        return;
                    }

                    // Use data-attraction-id so filtering/sorting doesn't break lookups
                    const card = targetElement.closest("[data-attraction-id]");
                    if (!card || !focusedPark) {
                        return;
                    }

                    const attractionId = card.getAttribute("data-attraction-id");
                    const attraction = focusedPark.attractions?.find((a) => a.id === attractionId);
                    if (!attraction) {
                        return;
                    }

                    window.openHomepageAttractionWidget?.({
                        parkTitle: focusedPark.title,
                        parkLocation: `${focusedPark.location}, ${focusedPark.country}`,
                        attractionTitle: attraction.title,
                        attractionSubtitle: attraction.subtitle,
                        attractionRating: attraction.rating,
                        attractionId: attraction.id
                    });
                };

                homePage.addEventListener("click", (event) => {
                    activateAttractionFromEvent(event.target);
                });

                homePage.addEventListener("keydown", (event) => {
                    if (event.key !== "Enter" && event.key !== " ") {
                        return;
                    }

                    const target = event.target;
                    if (!(target instanceof Element)) {
                        return;
                    }

                    if (target.closest("textarea, input, select, [contenteditable]")) {
                        return;
                    }

                    event.preventDefault();
                    activateAttractionFromEvent(target);
                });

                // STAR-36: re-render on search input
                getSearchInput()?.addEventListener("input", () => {
                    renderAttractionList(currentAttractions);
                });

                // STAR-35: re-render on sort change
                getSortSelect()?.addEventListener("change", () => {
                    renderAttractionList(currentAttractions);
                });
            };

            const setFocusedState = (focused, park) => {
                const locationPanel = getLocationPanel();
                const attractionPanelList = getAttractionPanelList();
                const attractionControls = getAttractionControls();
                homePage?.classList.toggle("is-park-focused", focused);
                focusedPark = focused ? park : null;

                if (locationPanel) {
                    if (focused) {
                        locationPanel.scrollTop = 0;
                    }
                    locationPanel.style.overflowY = focused ? "hidden" : "scroll";
                }

                // Show/hide search and sort controls alongside the attractions list
                if (attractionControls) {
                    attractionControls.hidden = !focused;
                }

                if (focused) {
                    map.dragPan.disable();
                    map.touchZoomRotate.disable();
                } else {
                    map.dragPan.enable();
                    map.touchZoomRotate.enable();
                }

                parkMarkers.forEach(({ element }) => {
                    element.style.display = focused ? "none" : "";
                });

                if (focused && park) {
                    renderAttractions(park);
                    addAttractionMarkers(park);
                } else {
                    clearAttractionMarkers();
                    window.closeHomepageAttractionWidget?.();
                    currentAttractions = [];
                    if (attractionPanelList) {
                        attractionPanelList.innerHTML = "";
                    }
                }
            };

            const getWrappedLngDistance = (a, b) => {
                const delta = Math.abs(a - b);
                return Math.min(delta, 360 - delta);
            };

            const isAtMaxZoom = () => {
                return Math.abs(map.getZoom() - initialZoom) <= resetZoomThreshold;
            };

            const updateResetButtonVisibility = () => {
                homePage?.classList.toggle("show-reset", !isAtMaxZoom());
            };

            const focusPark = (parkId) => {
                const park = parks.find((entry) => entry.id === parkId);
                if (!park) {
                    return;
                }

                setFocusedState(true, park);
                map.flyTo({
                    center: park.coordinates,
                    zoom: focusedZoom,
                    duration: 6000,
                    essential: true
                });
            };

            const resetGlobe = () => {
                setFocusedState(false, null);
                map.flyTo({
                    zoom: initialZoom,
                    duration: 6000,
                    essential: true
                });
            };

            window.focusHomepagePark = focusPark;
            window.resetHomepageGlobe = resetGlobe;

            bindAttractionPanelInteractions();
            map.on("moveend", updateResetButtonVisibility);
            map.on("load", updateResetButtonVisibility);

            parks.forEach((park) => {
                const markerElement = document.createElement("button");
                markerElement.type = "button";
                markerElement.className = "homepage-globe__marker";
                markerElement.setAttribute("aria-label", park.title);

                markerElement.addEventListener("click", () => {
                    focusPark(park.id);
                });

                const marker = new mapboxgl.Marker({ element: markerElement, anchor: "center" })
                    .setLngLat(park.coordinates)
                    .addTo(map);

                parkMarkers.push({ marker, element: markerElement });
            });

            setFocusedState(false, null);
            updateResetButtonVisibility();
        }

        if (!accessToken) {
            wrapper.classList.add("is-fallback");
            return;
        }

        if (window.mapboxgl) {
            if (document.readyState === "loading") {
                document.addEventListener("DOMContentLoaded", initHomepageGlobe, { once: true });
            } else {
                initHomepageGlobe();
            }
            return;
        }

        if (!document.getElementById("mapbox-gl-css")) {
            const stylesheet = document.createElement("link");
            stylesheet.id = "mapbox-gl-css";
            stylesheet.rel = "stylesheet";
            stylesheet.href = "https://api.mapbox.com/mapbox-gl-js/v3.20.0/mapbox-gl.css";
            document.head.appendChild(stylesheet);
        }

        if (!document.getElementById("mapbox-gl-sdk")) {
            const script = document.createElement("script");
            script.id = "mapbox-gl-sdk";
            script.async = true;
            script.defer = true;
            script.src = "https://api.mapbox.com/mapbox-gl-js/v3.20.0/mapbox-gl.js";
            script.addEventListener("load", initHomepageGlobe, { once: true });
            script.addEventListener("error", () => {
                wrapper.classList.add("is-fallback");
            }, { once: true });
            document.head.appendChild(script);
        }
    })();
</script>
