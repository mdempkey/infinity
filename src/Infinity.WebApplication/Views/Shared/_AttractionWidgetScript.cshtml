<script>
    (() => {
        const overlay = document.getElementById("attraction-widget-overlay");
        const dialog = document.getElementById("attraction-widget");
        const closeButton = document.getElementById("attraction-widget-close");

        const getTitleNode = () => document.getElementById("attraction-widget-title");
        const getParkNode = () => document.getElementById("attraction-widget-park");
        const getRatingNode = () => document.getElementById("attraction-widget-rating");
        const getSubtitleNode = () => document.getElementById("attraction-widget-subtitle");
        const getImageNode = () => document.getElementById("attraction-widget-image");
        const getReviewListNode = () => document.getElementById("attraction-review-list");
        const getReviewCountNode = () => document.getElementById("attraction-review-count");
        const getReviewDescriptionNode = () => document.getElementById("attraction-review-description");
        const getReviewStatusNode = () => document.getElementById("attraction-review-status");
        const getReviewForm = () => document.getElementById("attraction-review-form");
        const getReviewAttractionIdInput = () => document.getElementById("attraction-review-attraction-id");
        const getReviewTextInput = () => document.getElementById("attraction-review-text");
        const getReviewRatingInput = () => document.getElementById("attraction-review-rating");
        const getReviewSubmitButton = () => document.getElementById("attraction-review-submit");
        const getReviewAuthMessage = () => document.getElementById("attraction-review-auth-message");

        const buildStarRating = (rating) => {
            const roundedRating = Math.round(Number(rating) || 0);
            return `${"★".repeat(roundedRating)}${"☆".repeat(Math.max(0, 5 - roundedRating))}`;
        };

        const setReviewStatus = (message, isError = false) => {
            const statusNode = getReviewStatusNode();

            if (!statusNode) {
                return;
            }

            statusNode.textContent = message ?? "";
            statusNode.classList.toggle("text-danger", isError);
            statusNode.classList.toggle("text-success", !isError && !!message);
        };

        const renderReviews = (reviews) => {
            const reviewListNode = getReviewListNode();
            const reviewCountNode = getReviewCountNode();
            const reviewDescriptionNode = getReviewDescriptionNode();

            if (!reviewListNode || !reviewCountNode || !reviewDescriptionNode) {
                return;
            }

            reviewListNode.innerHTML = "";

            if (!reviews || reviews.length === 0) {
                reviewCountNode.textContent = "0 reviews";
                reviewDescriptionNode.textContent = "Be the first to share your thoughts.";
                return;
            }

            reviewCountNode.textContent = `${reviews.length} review${reviews.length === 1 ? "" : "s"}`;
            reviewDescriptionNode.textContent = "See what other guests are saying.";

            reviews.forEach(review => {
                const article = document.createElement("article");
                article.className = "border rounded-3 p-3 bg-light";

                const header = document.createElement("div");
                header.className = "d-flex justify-content-between align-items-center gap-3 mb-2";

                const author = document.createElement("p");
                author.className = "fw-semibold mb-0";
                author.textContent = review.authorName ?? "Guest";

                const rating = document.createElement("p");
                rating.className = "star-rating mb-0";
                rating.textContent = buildStarRating(review.rating);

                header.append(author, rating);

                const body = document.createElement("p");
                body.className = "mb-2 text-secondary";
                body.textContent = review.reviewText ?? "";

                const footer = document.createElement("p");
                footer.className = "mb-0 small text-secondary";
                footer.textContent = review.createdAtDisplay ?? "";

                article.append(header, body, footer);
                reviewListNode.append(article);
            });
        };

        const loadReviews = async (attractionId) => {
            try {
                const response = await fetch(`/api/attractions/${attractionId}/reviews`, {
                    headers: {
                        "Accept": "application/json"
                    }
                });

                if (!response.ok) {
                    throw new Error("Unable to load reviews right now.");
                }

                const payload = await response.json();
                renderReviews(payload.reviews ?? []);
            } catch (error) {
                renderReviews([]);
                setReviewStatus(error.message || "Unable to load reviews right now.", true);
            }
        };

        const resetReviewForm = (attractionId) => {
            const form = getReviewForm();
            const attractionIdInput = getReviewAttractionIdInput();
            const textInput = getReviewTextInput();
            const ratingInput = getReviewRatingInput();
            const authMessage = getReviewAuthMessage();

            if (form) {
                form.reset();
            }

            if (attractionIdInput) {
                attractionIdInput.value = attractionId ?? "";
            }

            if (textInput) {
                textInput.value = "";
            }

            if (ratingInput) {
                ratingInput.value = "5";
            }

            if (authMessage) {
                authMessage.hidden = !authMessage.dataset.requiresAuth;
            }

            setReviewStatus("");
        };

        const openWidget = ({ parkTitle, parkLocation, attractionTitle, attractionSubtitle, attractionRating, attractionId, attractionImageUrl }) => {
            const titleNode = getTitleNode();
            const parkNode = getParkNode();
            const ratingNode = getRatingNode();
            const subtitleNode = getSubtitleNode();
            const imageNode = getImageNode();

            if (!overlay || !dialog || !titleNode || !parkNode || !ratingNode || !subtitleNode) {
                return;
            }

            parkNode.textContent = `${parkTitle} • ${parkLocation}`;
            titleNode.textContent = attractionTitle;
            ratingNode.textContent = buildStarRating(attractionRating);
            subtitleNode.textContent = attractionSubtitle ?? "";

            if (imageNode) {
                if (attractionImageUrl) {
                    imageNode.src = attractionImageUrl;
                    imageNode.alt = attractionTitle;
                    imageNode.hidden = false;
                } else {
                    imageNode.src = "";
                    imageNode.alt = "";
                    imageNode.hidden = true;
                }
            }

            overlay.hidden = false;
            document.body.classList.add("overflow-hidden");

            resetReviewForm(attractionId);
            loadReviews(attractionId);
            closeButton?.focus();
        };

        const closeWidget = () => {
            if (!overlay) {
                return;
            }

            overlay.hidden = true;
            document.body.classList.remove("overflow-hidden");
            setReviewStatus("");
        };

        overlay?.addEventListener("click", (event) => {
            if (event.target === overlay) {
                closeWidget();
            }
        });

        closeButton?.addEventListener("click", closeWidget);

        document.addEventListener("keydown", (event) => {
            if (event.key === "Escape" && overlay && !overlay.hidden) {
                closeWidget();
            }
        });

        getReviewForm()?.addEventListener("submit", async (event) => {
            event.preventDefault();

            const submitButton = getReviewSubmitButton();
            const attractionIdInput = getReviewAttractionIdInput();
            const textInput = getReviewTextInput();
            const ratingInput = getReviewRatingInput();

            const attractionId = attractionIdInput?.value;
            const reviewText = textInput?.value?.trim();
            const rating = Number(ratingInput?.value ?? 0);

            if (!attractionId || !reviewText || !rating) {
                setReviewStatus("Please complete all review fields before submitting.", true);
                return;
            }

            try {
                if (submitButton) {
                    submitButton.disabled = true;
                }

                setReviewStatus("Submitting your review...");

                const response = await fetch("/api/reviews", {
                    method: "POST",
                    headers: {
                        "Content-Type": "application/json",
                        "Accept": "application/json"
                    },
                    body: JSON.stringify({
                        attractionId,
                        rating,
                        reviewText
                    })
                });

                if (response.status === 401) {
                    setReviewStatus("Please sign in to leave a review.", true);
                    return;
                }

                if (!response.ok) {
                    const problem = await response.json().catch(() => null);
                    const detail = problem?.detail || "We couldn't save your review right now.";
                    throw new Error(detail);
                }

                if (textInput) {
                    textInput.value = "";
                }

                if (ratingInput) {
                    ratingInput.value = "5";
                }

                setReviewStatus("Thanks! Your review was added.");
                await loadReviews(attractionId);
            } catch (error) {
                setReviewStatus(error.message || "We couldn't save your review right now.", true);
            } finally {
                if (submitButton) {
                    submitButton.disabled = false;
                }
            }
        });

        window.openHomepageAttractionWidget = openWidget;
        window.closeHomepageAttractionWidget = closeWidget;
    })();
</script>