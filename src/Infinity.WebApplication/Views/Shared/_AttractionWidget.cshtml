<style>
    .attraction-widget__gallery {
        margin-top: 1rem;
        padding-top: 1rem;
        border-top: 1px solid rgba(255,255,255,0.12);
    }

    .attraction-widget__gallery-toggle {
        border: 1px solid rgba(255, 204, 0, 0.25);
        border-radius: 999px;
        padding: 0.45rem 0.9rem;
        background: rgba(255,255,255,0.05);
        color: white;
        font-weight: 600;
    }

    .attraction-widget__gallery-panel[hidden] {
        display: none !important;
    }

    .attraction-widget__gallery-panel {
        margin-top: 0.85rem;
    }

    .attraction-widget__gallery-frame {
        width: 100%;
        aspect-ratio: 16 / 9;
        overflow: hidden;
        border-radius: 16px;
        border: 1px solid rgba(255,255,255,0.12);
        background: rgba(255,255,255,0.04);
    }

    .attraction-widget__gallery-image {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
    }

    .attraction-widget__gallery-controls {
        display: flex;
        gap: 0.5rem;
        flex-wrap: wrap;
        margin-top: 0.75rem;
    }

    .attraction-widget__gallery-btn {
        border: 1px solid rgba(255, 204, 0, 0.25);
        border-radius: 999px;
        padding: 0.4rem 0.85rem;
        background: rgba(255,255,255,0.05);
        color: white;
        font-weight: 600;
    }

    .attraction-widget__gallery-meta {
        margin-top: 0.5rem;
        font-size: 0.9rem;
        color: rgba(255,255,255,0.75);
    }
</style>

<div class="attraction-widget-overlay" id="attraction-widget-overlay" hidden>
    <article class="attraction-widget card text-bg" id="attraction-widget" role="dialog" aria-modal="true" aria-labelledby="attraction-widget-title">
        <button type="button" class="attraction-widget__close btn-close" id="attraction-widget-close" aria-label="Close attraction details"></button>
        <p class="attraction-widget__eyebrow text-uppercase small text-secondary mb-2" id="attraction-widget-park"></p>
        <h2 class="h3 text-primary mb-1" id="attraction-widget-title"></h2>
        <p class="star-rating attraction-widget__rating" id="attraction-widget-rating"></p>
        <p class="attraction-widget__subtitle text-secondary mb-0" id="attraction-widget-subtitle"></p>

        <div class="attraction-widget__image-wrapper mt-3 mb-3">
            <img id="attraction-widget-image"
                 class="img-fluid rounded w-100"
                 alt=""
                 loading="lazy"
                 hidden />
        </div>

        <section class="attraction-widget__gallery" aria-label="Attraction photo gallery">
            <button type="button"
                    class="attraction-widget__gallery-toggle"
                    id="attraction-gallery-toggle"
                    hidden>
                Open photo gallery
            </button>

            <div class="attraction-widget__gallery-panel" id="attraction-gallery-panel" hidden>
                <div class="attraction-widget__gallery-frame">
                    <img id="attraction-gallery-image"
                         class="attraction-widget__gallery-image"
                         alt=""
                         loading="lazy" />
                </div>

                <div class="attraction-widget__gallery-controls">
                    <button type="button" class="attraction-widget__gallery-btn" id="attraction-gallery-prev">Prev</button>
                    <button type="button" class="attraction-widget__gallery-btn" id="attraction-gallery-next">Next</button>
                    <button type="button" class="attraction-widget__gallery-btn" id="attraction-gallery-shuffle">Shuffle</button>
                </div>

                <div class="attraction-widget__gallery-meta" id="attraction-gallery-meta"></div>
            </div>
        </section>

        <partial name="_Reviews" />
    </article>
</div>

<partial name="_ReviewsScript" />
<partial name="_AttractionWidgetScript" />