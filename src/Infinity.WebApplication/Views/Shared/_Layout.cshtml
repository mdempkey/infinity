<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: "Segoe UI", Tahoma, Geneva, Verdana, sans-serif;
        }

        body {
            min-height: 100vh;
            background:
                radial-gradient(circle at top, rgba(255, 204, 0, 0.1), transparent 30%),
                linear-gradient(180deg, #05070d 0%, #111827 50%, #05070d 100%);
            color: #ffffff;
        }

        a {
            color: inherit;
            text-decoration: none;
        }

        button {
            font: inherit;
        }

        .navbar {
            display: flex;
            justify-content: flex-end;
            padding: 20px 50px;
            background-color: rgba(5, 7, 13, 0.92);
            border-bottom: 1px solid rgba(255, 255, 255, 0.08);
            position: sticky;
            top: 0;
            backdrop-filter: blur(12px);
            z-index: 10;
        }

        .nav-links {
            display: flex;
            gap: 16px;
        }

        .nav-link-button {
            background: transparent;
            border: none;
            color: #ffffff;
            cursor: pointer;
            font-size: 0.95rem;
        }

        .nav-link-button:hover {
            color: #ffcc00;
        }

        main {
            max-width: 1100px;
            margin: 0 auto;
            padding: 48px 20px 72px;
        }

        .hero-section {
            display: grid;
            gap: 36px;
        }

        .hero {
            text-align: center;
        }

        .eyebrow {
            color: #ffcc00;
            text-transform: uppercase;
            letter-spacing: 0.2rem;
            margin-bottom: 12px;
            font-size: 0.8rem;
        }

        h1 {
            font-size: clamp(3rem, 10vw, 5.5rem);
            letter-spacing: 0.25rem;
            color: #ffcc00;
        }

        h2 {
            font-size: clamp(1.5rem, 4vw, 2.4rem);
            margin-bottom: 8px;
        }

        h3 {
            font-size: 1.1rem;
        }

        p {
            color: #c7cedb;
            line-height: 1.5;
        }

        .map-container {
            margin-top: 40px;
            display: flex;
            justify-content: center;
        }

        .image-placeholder {
            background: linear-gradient(180deg, rgba(21, 32, 58, 0.95), rgba(10, 13, 24, 0.95));
            border: 1px solid rgba(255, 255, 255, 0.09);
            display: flex;
            align-items: center;
            justify-content: center;
            color: #6f7a8d;
            position: relative;
            border-radius: 18px;
            overflow: hidden;
        }

        .map-globe {
            width: min(420px, 88vw);
            height: min(420px, 88vw);
            border-radius: 50%;
            box-shadow: 0 30px 60px rgba(0, 0, 0, 0.35);
        }

        .marker {
            position: absolute;
            width: 22px;
            height: 22px;
            background-color: #ffcc00;
            border-radius: 50%;
            border: 3px solid #10131d;
            cursor: pointer;
            transition: transform 0.2s ease, box-shadow 0.2s ease;
        }

        .marker:hover {
            transform: scale(1.25);
            box-shadow: 0 0 0 8px rgba(255, 204, 0, 0.16);
        }

        .ca-marker { top: 35%; left: 20%; }
        .paris-marker { top: 30%; left: 55%; }

        .park-previews,
        .attraction-list {
            display: grid;
            gap: 24px;
        }

        .park-previews {
            grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
        }

        .attraction-card {
            background: rgba(12, 17, 28, 0.9);
            border: 1px solid rgba(255, 255, 255, 0.08);
            padding: 24px;
            border-radius: 20px;
            box-shadow: 0 24px 50px rgba(0, 0, 0, 0.25);
        }

        .inline-btn {
            display: inline-block;
            margin-top: 16px;
        }

        .park-detail-page {
            max-width: 840px;
            margin: 0 auto;
        }

        .park-header {
            margin: 16px 0 28px;
            border-bottom: 1px solid rgba(255, 255, 255, 0.1);
            padding-bottom: 18px;
        }

        .link-btn,
        .back-btn {
            color: #c7cedb;
            display: inline-block;
            margin-bottom: 8px;
        }

        .link-btn:hover,
        .back-btn:hover {
            color: #ffffff;
        }

        .attraction-img {
            width: 100%;
            min-height: 240px;
            margin: 16px 0;
        }

        .star-rating {
            color: #ffcc00;
            font-size: 1.05rem;
            margin-top: 10px;
        }

        .review-prompt,
        .reviews-section {
            background-color: rgba(255, 255, 255, 0.04);
            padding: 18px;
            border-radius: 14px;
            margin-top: 16px;
        }

        .review-prompt {
            display: grid;
            justify-items: start;
            gap: 10px;
        }

        .yellow-btn {
            background-color: #ffcc00;
            color: #000000;
            border: none;
            padding: 11px 20px;
            border-radius: 999px;
            font-weight: 700;
            cursor: pointer;
        }

        .yellow-btn:hover {
            background-color: #e6b800;
        }

        .full-width {
            width: 100%;
        }

        .reviews-section h3 {
            margin-bottom: 14px;
        }

        .review-item + .review-item {
            margin-top: 16px;
        }

        .reviewer-info {
            display: flex;
            align-items: center;
            gap: 10px;
            margin-bottom: 8px;
        }

        .avatar {
            width: 32px;
            height: 32px;
            border-radius: 50%;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            font-size: 0.75rem;
            font-weight: 700;
            background: rgba(255, 204, 0, 0.15);
            color: #ffcc00;
        }

        .date,
        .empty-reviews {
            color: #8c97ab;
            font-style: italic;
        }

        .date {
            margin-left: auto;
            font-size: 0.85rem;
        }

        .modal-overlay {
            display: none;
            position: fixed;
            inset: 0;
            background-color: rgba(0, 0, 0, 0.8);
            z-index: 20;
            justify-content: center;
            align-items: center;
            padding: 20px;
        }

        .modal-content {
            width: min(420px, 100%);
            background: #0c111c;
            border: 1px solid rgba(255, 255, 255, 0.08);
            padding: 32px;
            border-radius: 20px;
            position: relative;
        }

        .close-btn {
            position: absolute;
            top: 14px;
            right: 18px;
            background: transparent;
            border: none;
            font-size: 1.8rem;
            color: #c7cedb;
            cursor: pointer;
        }

        .form-input {
            width: 100%;
            padding: 12px;
            margin: 10px 0;
            background-color: #121827;
            border: 1px solid rgba(255, 255, 255, 0.12);
            color: #ffffff;
            border-radius: 10px;
        }

        @@media (max-width: 640px) {
            .navbar {
                padding: 18px 20px;
            }

            main {
                padding-top: 32px;
            }

            .reviewer-info {
                align-items: flex-start;
                flex-wrap: wrap;
            }

            .date {
                margin-left: 0;
                width: 100%;
            }
        }
    </style>
</head>
<body>
<header class="navbar">
    <nav class="nav-links">
        <button type="button" class="nav-link-button" onclick="showLoginModal()">Log In</button>
        <button type="button" class="nav-link-button" onclick="showLoginModal()">Sign Up</button>
    </nav>
</header>
<main>
        @RenderBody()
</main>
<div id="login-modal" class="modal-overlay">
    <div class="modal-content">
        <button type="button" class="close-btn" onclick="hideLoginModal()" aria-label="Close">&times;</button>
        <h2>Welcome to Star Wars Attractions</h2>
        <p>Log In</p>
        <form onsubmit="event.preventDefault(); hideLoginModal();">
            <input type="email" placeholder="Email" class="form-input" required />
            <input type="password" placeholder="Password" class="form-input" required />
            <button type="submit" class="yellow-btn full-width">Log In</button>
        </form>
    </div>
</div>
<script>
    function showLoginModal() {
        const modal = document.getElementById("login-modal");
        if (modal) {
            modal.style.display = "flex";
        }
    }

    function hideLoginModal() {
        const modal = document.getElementById("login-modal");
        if (modal) {
            modal.style.display = "none";
        }
    }

    window.addEventListener("click", (event) => {
        const modal = document.getElementById("login-modal");
        if (modal && event.target === modal) {
            hideLoginModal();
        }
    });
</script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
