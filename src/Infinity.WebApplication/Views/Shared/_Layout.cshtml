<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: "Segoe UI", Tahoma, Geneva, Verdana, sans-serif;
        }

        body {
            min-height: 100vh;
            background:
                radial-gradient(circle at top, rgba(255, 204, 0, 0.1), transparent 30%),
                linear-gradient(180deg, #05070d 0%, #111827 50%, #05070d 100%);
            color: #ffffff;
        }

        body:has(.home-page) {
            overflow: hidden;
        }

        body:has(.park-detail-page) {
            overflow: hidden;
        }

        a {
            color: inherit;
            text-decoration: none;
        }

        button {
            font: inherit;
        }

        .navbar {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 20px 50px;
            background-color: rgba(5, 7, 13, 0.92);
            border-bottom: 1px solid rgba(255, 255, 255, 0.08);
            position: sticky;
            top: 0;
            backdrop-filter: blur(12px);
            z-index: 10;
        }

        .nav-links {
            display: flex;
            gap: 16px;
            align-items: center;
        }

        .site-title {
            display: inline-flex;
            flex-direction: column;
            gap: 2px;
        }

        .site-title__name {
            font-size: 1.15rem;
            font-weight: 800;
            letter-spacing: 0.18rem;
            color: #ffcc00;
        }

        .site-title__tag {
            font-size: 0.75rem;
            letter-spacing: 0.18rem;
            text-transform: uppercase;
            color: #c7cedb;
        }

        .nav-link-button {
            background: transparent;
            border: none;
            color: #c7cedb;
            cursor: pointer;
            font-size: 0.95rem;
        }

        .nav-link-button:hover {
            color: #ffcc00;
        }

        main {
            padding: 0 0 72px;
        }

        .home-page {
            position: relative;
            height: calc(100vh - 81px);
            min-height: calc(100vh - 81px);
            width: 100vw;
            margin-left: calc(50% - 50vw);
            overflow: hidden;
        }

        .home-page__background,
        .homepage-globe,
        .home-page__scrim {
            position: absolute;
            inset: 0;
        }

        .home-page__background {
            z-index: 0;
            background: #05070d;
        }

        .homepage-globe {
            overflow: hidden;
        }

        #homepage-globe {
            position: absolute;
            inset: 0 auto 0 0;
            width: 130%;
            height: 100%;
            transform: translateX(-22.5%);
        }

        .homepage-globe.is-ready .homepage-globe__fallback {
            opacity: 0;
            visibility: hidden;
        }

        .homepage-globe__fallback {
            position: absolute;
            inset: 0;
            z-index: 4;
            display: flex;
            align-items: center;
            justify-content: center;
            color: rgba(255, 255, 255, 0.55);
            background:
                radial-gradient(circle at 32% 50%, rgba(54, 89, 154, 0.45), transparent 28%),
                radial-gradient(circle at 32% 50%, rgba(255, 204, 0, 0.08), transparent 45%),
                linear-gradient(180deg, #09111f 0%, #05070d 100%);
            transition: opacity 0.25s ease;
            pointer-events: none;
        }

        .homepage-globe .mapboxgl-canvas,
        .homepage-globe .mapboxgl-canvas-container {
            width: 100% !important;
            height: 100% !important;
        }

        .homepage-globe .mapboxgl-canvas-container {
            z-index: 0;
        }

        .homepage-globe__marker {
            width: 16px;
            height: 16px;
            border: 2px solid #10131d;
            border-radius: 999px;
            background: #ffcc00;
            box-shadow:
                0 0 10px rgba(255, 204, 0, 0.75),
                0 0 22px rgba(255, 204, 0, 0.45),
                0 0 40px rgba(255, 204, 0, 0.2);
            cursor: pointer;
        }

        .home-page__scrim {
            z-index: 1;
            background:
                radial-gradient(circle at center, transparent 0%, rgba(5, 7, 13, 0.08) 48%, rgba(5, 7, 13, 0.56) 100%),
                linear-gradient(180deg, rgba(5, 7, 13, 0.18) 0%, rgba(5, 7, 13, 0.42) 100%);
            pointer-events: none;
        }

        .home-page__reset {
            position: absolute;
            top: 24px;
            left: 24px;
            z-index: 3;
            display: none;
            padding: 10px 16px;
            border-radius: 999px;
            border: 1px solid rgba(255, 255, 255, 0.12);
            background: rgba(12, 17, 28, 0.78);
            color: #c7cedb;
            line-height: 1;
            backdrop-filter: blur(10px);
            cursor: pointer;
            transition: box-shadow 0.2s ease, border-color 0.2s ease, transform 0.2s ease;
        }

        .home-page__reset:hover,
        .home-page__reset:focus-visible {
            border-color: rgba(255, 204, 0, 0.75);
            transform: translateY(-1px);
        }

        .home-page.is-park-focused .home-page__reset {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
        }

        .home-page.show-reset .home-page__reset {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
        }

        .attraction-widget-overlay {
            position: absolute;
            inset: 0;
            z-index: 5;
            display: grid;
            place-items: center;
            background: rgba(5, 7, 13, 0.45);
            pointer-events: auto;
        }

        .attraction-widget-overlay[hidden] {
            display: none;
        }

        .attraction-widget {
            width: min(560px, calc(100vw - 48px));
            background: rgba(12, 17, 28, 0.95);
            border: 1px solid rgba(255, 255, 255, 0.14);
            border-radius: 20px;
            padding: 30px 28px;
            position: relative;
            box-shadow:
                0 16px 44px rgba(0, 0, 0, 0.45),
                0 0 0 1px rgba(255, 204, 0, 0.16);
        }

        .attraction-widget__close {
            position: absolute;
            top: 14px;
            right: 14px;
            width: 34px;
            height: 34px;
            border-radius: 999px;
            border: 1px solid rgba(255, 255, 255, 0.2);
            background: rgba(255, 255, 255, 0.06);
            color: #c7cedb;
            cursor: pointer;
            font-size: 1.2rem;
            line-height: 1;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            padding: 0;
        }

        .attraction-widget__close-glyph {
            display: inline-block;
            transform: translateY(-1px);
        }

        .attraction-widget__eyebrow {
            text-transform: uppercase;
            letter-spacing: 0.09rem;
            font-size: 0.72rem;
            color: #a6b0c3;
            margin-bottom: 8px;
        }

        .attraction-widget__subtitle {
            margin-top: 10px;
            color: #d1d7e2;
            font-size: 1.02rem;
        }

        .attraction-widget__rating {
            margin-top: 4px;
            margin-bottom: 2px;
        }

        .attraction-widget__reviews {
            margin-top: 18px;
            padding-top: 14px;
            border-top: 1px solid rgba(255, 255, 255, 0.12);
        }

        .attraction-widget__reviews-title {
            margin-bottom: 10px;
            font-size: 0.95rem;
            letter-spacing: 0.03rem;
            text-transform: uppercase;
            color: #ffcc00;
        }

        .attraction-widget__review + .attraction-widget__review {
            margin-top: 10px;
            padding-top: 10px;
            border-top: 1px solid rgba(255, 255, 255, 0.08);
        }

        .attraction-widget__review-meta {
            display: flex;
            justify-content: space-between;
            gap: 10px;
            margin-bottom: 4px;
            color: #a6b0c3;
            font-size: 0.78rem;
        }

        .attraction-widget__review-comment {
            margin: 0;
            font-size: 0.92rem;
            color: #d1d7e2;
        }

        .attraction-widget__reviews-empty {
            margin: 0;
            color: #a6b0c3;
            font-size: 0.9rem;
        }

        .attraction-widget__review-composer {
            margin-top: 14px;
            display: grid;
            gap: 8px;
        }

        .attraction-widget__review-label {
            font-size: 0.82rem;
            color: #a6b0c3;
        }

        .attraction-widget__review-input {
            width: 100%;
            resize: vertical;
            min-height: 88px;
            border-radius: 12px;
            border: 1px solid rgba(255, 255, 255, 0.18);
            background: rgba(255, 255, 255, 0.05);
            color: #f0f3f8;
            padding: 10px 12px;
            font: inherit;
            line-height: 1.35;
        }

        .attraction-widget__review-input:focus-visible {
            outline: 2px solid rgba(255, 204, 0, 0.8);
            outline-offset: 1px;
        }

        .attraction-widget__review-submit {
            justify-self: start;
            margin-top: 2px;
        }

        .attraction-widget__review-note {
            margin-top: 14px;
            margin-bottom: 0;
            color: #a6b0c3;
            font-size: 0.9rem;
        }

        .home-page__content {
            position: relative;
            z-index: 2;
            margin: 0 auto;
            padding: 40px;
            height: calc(100vh - 81px);
            display: flex;
            justify-content: flex-end;
            align-items: flex-start;
            pointer-events: none;
        }

        .home-hero {
            width: min(420px, 100%);
            max-height: 100%;
        }

        h1 {
            font-size: clamp(3rem, 10vw, 5.5rem);
            letter-spacing: 0.25rem;
            color: #ffcc00;
        }

        h2 {
            font-size: clamp(1.5rem, 4vw, 2.4rem);
            margin-bottom: 8px;
            color: #ffcc00;
        }

        h3 {
            font-size: 1.1rem;
            color: #ffcc00;
        }

        p {
            color: #c7cedb;
            line-height: 1.5;
        }

        .image-placeholder {
            background: linear-gradient(180deg, rgba(21, 32, 58, 0.95), rgba(10, 13, 24, 0.95));
            border: 1px solid rgba(255, 255, 255, 0.09);
            display: flex;
            align-items: center;
            justify-content: center;
            color: #6f7a8d;
            position: relative;
            border-radius: 18px;
            overflow: hidden;
        }

        .park-previews,
        .attraction-list {
            display: grid;
            gap: 24px;
        }

        .location-panel {
            display: grid;
            gap: 18px;
            justify-items: stretch;
            max-height: 100%;
            padding-top: 10px;
            overflow-y: scroll;
            scrollbar-width: none;
            overscroll-behavior: contain;
            -ms-overflow-style: none;
            pointer-events: auto;
        }

        .attraction-panel {
            display: none;
        }

        .home-page.is-park-focused .location-panel {
            overflow: hidden;
        }

        .home-page.is-park-focused .location-panel--parks {
            display: none;
        }

        .home-page.is-park-focused .attraction-panel {
            display: grid;
        }

        .home-page.is-park-focused .homepage-globe .mapboxgl-canvas-container,
        .home-page.is-park-focused .homepage-globe .mapboxgl-canvas-container.mapboxgl-interactive,
        .home-page.is-park-focused .homepage-globe .mapboxgl-canvas-container.mapboxgl-interactive:active,
        .home-page.is-park-focused .homepage-globe .mapboxgl-canvas {
            cursor: default !important;
        }

        .location-panel::-webkit-scrollbar {
            display: none;
        }

        .attraction-summary + .attraction-summary {
            margin-top: 14px;
            padding-top: 14px;
            border-top: 1px solid rgba(255, 255, 255, 0.12);
        }

        .attraction-summary--clickable {
            cursor: pointer;
            transition: box-shadow 0.2s ease, border-color 0.2s ease, transform 0.2s ease;
        }

        .attraction-summary--clickable:hover,
        .attraction-summary--clickable:focus-visible {
            border-color: #ffcc00;
            transform: translateY(-1px);
        }

        .attraction-summary h4 {
            font-size: 1rem;
            color: #ffffff;
            margin-bottom: 4px;
        }

        .attraction-summary p {
            font-size: 0.9rem;
        }

        .attraction-card {
            background: rgba(12, 17, 28, 0.9);
            border: 1px solid rgba(255, 255, 255, 0.08);
            padding: 24px;
            border-radius: 20px;
        }

        .location-card--clickable {
            cursor: pointer;
            transition: box-shadow 0.2s ease, border-color 0.2s ease, transform 0.2s ease;
        }

        .location-card--clickable:hover,
        .location-card--clickable:focus-visible {
            border-color: #ffcc00;
            transform: translateY(-1px);
        }

        .location-card--clickable:focus-visible {
            outline: 2px solid #ffcc00;
            outline-offset: 2px;
        }

        .inline-btn {
            display: inline-block;
            margin-top: 16px;
        }

        .park-detail-page {
            max-width: 840px;
            margin: 0 auto;
            padding: 48px 20px 0;
            height: calc(100vh - 81px);
            overflow-y: auto;
            overscroll-behavior: contain;
            scrollbar-width: none;
            -ms-overflow-style: none;
        }

        .park-detail-page::-webkit-scrollbar {
            display: none;
        }

        .park-header {
            margin: 16px 0 28px;
            border-bottom: 1px solid rgba(255, 255, 255, 0.1);
            padding-bottom: 18px;
        }

        .link-btn,
        .back-btn {
            color: #c7cedb;
            display: inline-block;
            margin-bottom: 8px;
        }

        .link-btn:hover,
        .back-btn:hover {
            color: #ffffff;
        }

        .attraction-img {
            width: 100%;
            min-height: 240px;
            margin: 16px 0;
        }

        .star-rating {
            color: #ffcc00;
            font-size: 1.05rem;
        }

        .star-rating--five {
            display: inline-flex;
            align-items: center;
            line-height: 1;
            font-size: 1rem;
            margin-top: 8px;
            gap: 0.4rem;
        }

        .star-rating__stars {
            display: inline-flex;
            gap: 0.14rem;
        }

        .star-rating__star {
            position: relative;
            display: inline-block;
            color: rgba(255, 255, 255, 0.28);
        }

        .star-rating__star--full {
            color: #ffcc00;
            filter: drop-shadow(0 0 8px rgba(255, 204, 0, 0.35));
        }

        .star-rating__star--half::after {
            content: "★";
            position: absolute;
            top: 0;
            left: 0;
            width: 50%;
            overflow: hidden;
            white-space: nowrap;
            color: #ffcc00;
            filter: drop-shadow(0 0 8px rgba(255, 204, 0, 0.35));
        }

        .star-rating__value {
            color: #ffcc00;
            font-size: 0.88rem;
            letter-spacing: 0.02rem;
        }

        .review-prompt,
        .reviews-section {
            background-color: rgba(255, 255, 255, 0.04);
            padding: 18px;
            border-radius: 14px;
            margin-top: 16px;
        }

        .review-prompt {
            display: grid;
            justify-items: start;
            gap: 10px;
        }

        .yellow-btn {
            background-color: #ffcc00;
            color: #000000;
            border: none;
            padding: 11px 20px;
            border-radius: 999px;
            font-weight: 700;
            cursor: pointer;
        }

        .yellow-btn:hover {
            background-color: #e6b800;
        }

        .full-width {
            width: 100%;
        }

        .reviews-section h3 {
            margin-bottom: 14px;
        }

        .review-item + .review-item {
            margin-top: 16px;
        }

        .reviewer-info {
            display: flex;
            align-items: center;
            gap: 10px;
            margin-bottom: 8px;
        }

        .avatar {
            width: 32px;
            height: 32px;
            border-radius: 50%;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            font-size: 0.75rem;
            font-weight: 700;
            background: rgba(255, 204, 0, 0.15);
            color: #ffcc00;
        }

        .date,
        .empty-reviews {
            color: #8c97ab;
            font-style: italic;
        }

        .date {
            margin-left: auto;
            font-size: 0.85rem;
        }

        .modal-overlay {
            display: none;
            position: fixed;
            inset: 0;
            background-color: rgba(0, 0, 0, 0.8);
            z-index: 20;
            justify-content: center;
            align-items: center;
            padding: 20px;
        }

        .modal-content {
            width: min(420px, 100%);
            background: #0c111c;
            border: 1px solid rgba(255, 255, 255, 0.08);
            padding: 32px;
            border-radius: 20px;
            position: relative;
        }

        .close-btn {
            position: absolute;
            top: 14px;
            right: 18px;
            background: transparent;
            border: none;
            font-size: 1.8rem;
            color: #c7cedb;
            cursor: pointer;
        }

        .form-input {
            width: 100%;
            padding: 12px;
            margin: 10px 0;
            background-color: #121827;
            border: 1px solid rgba(255, 255, 255, 0.12);
            color: #ffffff;
            border-radius: 10px;
        }

        @@media (max-width: 640px) {
            .navbar {
                padding: 20px;
                gap: 16px;
                align-items: flex-start;
                flex-direction: column;
            }

            main {
                padding-bottom: 48px;
            }

            .home-page {
                height: calc(100vh - 73px);
                min-height: calc(100vh - 73px);
            }

            .home-page__content {
                padding-top: 32px;
                height: calc(100vh - 73px);
            }

            .home-page__reset {
                top: 18px;
                left: 18px;
            }

            #homepage-globe {
                width: 100%;
                transform: none;
            }

            .homepage-globe__fallback {
                background:
                    radial-gradient(circle at 50% 50%, rgba(54, 89, 154, 0.45), transparent 28%),
                    radial-gradient(circle at 50% 50%, rgba(255, 204, 0, 0.08), transparent 45%),
                    linear-gradient(180deg, #09111f 0%, #05070d 100%);
            }

            .home-hero {
                width: 100%;
            }

            .location-panel {
                width: 100%;
            }

            .park-detail-page {
                height: calc(100vh - 73px);
            }

            .reviewer-info {
                align-items: flex-start;
                flex-wrap: wrap;
            }

            .date {
                margin-left: 0;
                width: 100%;
            }
        }
    </style>
</head>
<body>
<header class="navbar">
    <a class="site-title" asp-controller="Home" asp-action="Index" aria-label="Star Wars Attractions home">
        <span class="site-title__name">STAR WARS</span>
        <span class="site-title__tag">Themed Attractions</span>
    </a>
    <nav class="nav-links">
        <button type="button" class="nav-link-button" onclick="showLoginModal()">Log In</button>
        <button type="button" class="nav-link-button" onclick="showLoginModal()">Sign Up</button>
    </nav>
</header>
<main>
        @RenderBody()
</main>
<div id="login-modal" class="modal-overlay">
    <div class="modal-content">
        <button type="button" class="close-btn" onclick="hideLoginModal()" aria-label="Close">&times;</button>
        <h2>Welcome to Star Wars Attractions</h2>
        <p>Log In</p>
        <form onsubmit="event.preventDefault(); hideLoginModal();">
            <input type="email" placeholder="Email" class="form-input" required />
            <input type="password" placeholder="Password" class="form-input" required />
            <button type="submit" class="yellow-btn full-width">Log In</button>
        </form>
    </div>
</div>
<script>
    function showLoginModal() {
        const modal = document.getElementById("login-modal");
        if (modal) {
            modal.style.display = "flex";
        }
    }

    function hideLoginModal() {
        const modal = document.getElementById("login-modal");
        if (modal) {
            modal.style.display = "none";
        }
    }

    window.addEventListener("click", (event) => {
        const modal = document.getElementById("login-modal");
        if (modal && event.target === modal) {
            hideLoginModal();
        }
    });
</script>
<partial name="_StarRatingScript" />
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
